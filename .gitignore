__pycache__/
*.py[codz]
.env
.venv/
.ruff_cache/
.mypy_cache/
*.egg-info/

# Prevent accidental nested output directory
output/output/

# Release archives (generated by build_formats.py --release-assets)
output/ipnova-formats.tar.gz
output/SHA256SUMS

# Geolocation cache — large (~1MB), derived data, stored via GitHub Actions
# cache instead of git history to avoid unbounded repo growth (~13MB/year).
# CI restores this from cache before generate_ip_list.py runs, and saves it
# after, so warm runs still benefit from the 168h TTL speedup.
output/.geoloc_cache.json
